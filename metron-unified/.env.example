# ── LLM Providers (set at least one) ─────────────────────────────────────────
GROQ_API_KEY=
GEMINI_API_KEY=
NVIDIA_NIM_API_KEY=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_API_VERSION=2025-01-01-preview

# ── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=
# Set to "true" once you have HTTPS/SSL configured (nginx + certbot)
METRON_SECURE_COOKIE=false

# ── Optional ──────────────────────────────────────────────────────────────────
HUGGINGFACE_TOKEN=

# ── Database (use an absolute path in production) ─────────────────────────────
METRON_DB_PATH=/opt/metron/data/metron_runs.db

# ── CORS (comma-separated list of allowed origins) ────────────────────────────
# Add your EC2 public IP or domain here.
# Example: CORS_ORIGINS=http://1.2.3.4,https://yourdomain.com
CORS_ORIGINS=
