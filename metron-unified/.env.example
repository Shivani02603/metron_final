# ── LLM Provider Keys ─────────────────────────────────────────────────────────
# LLM API keys are provided through the MetronAI UI (Configure page → API Key field).
# They are NOT read from environment variables. Do not add them here.
#
# Supported providers (configured in the UI):
#   - Groq
#   - Google Gemini
#   - NVIDIA NIM
#   - Azure OpenAI

# ── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=
# Set to "true" once you have HTTPS/SSL configured (nginx + certbot)
METRON_SECURE_COOKIE=false

# ── Database (use an absolute path in production) ─────────────────────────────
# METRON_DB_PATH=/opt/metron/data/metron_runs.db

# ── CORS (comma-separated list of allowed origins) ────────────────────────────
# Add your server's public IP or domain here.
# Example: CORS_ORIGINS=http://1.2.3.4,https://yourdomain.com
CORS_ORIGINS=

# ── Frontend (optional — set if backend is not on localhost:8000) ─────────────
# NEXT_PUBLIC_API_URL=http://your-server-ip:8000
